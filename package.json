{
  "name": "kick-ad-blocker",
  "version": "1.0.0",
  "private": true,
  "description": "Block ads on Kick.com — lightweight MV3 extension for Chrome & Firefox.",
  "license": "MIT",
  "author": "Pkkls",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b --noEmit && vite build && tsx scripts/bundle-content.ts",
    "build:firefox": "BROWSER=firefox vite build && tsx scripts/bundle-content.ts",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "tsx scripts/generate-icons.ts",
    "pack": "tsx scripts/pack.ts"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@preact/preset-vite": "^2.9.1",
    "@types/chrome": "^0.0.283",
    "@types/node": "^22.7.4",
    "@vitest/coverage-v8": "^2.1.2",
    "autoprefixer": "^10.4.20",
    "happy-dom": "^15.7.4",
    "postcss": "^8.4.47",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  },
  "dependencies": {
    "preact": "^10.24.2",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=20"
  }
}
