{
  "manifest_version": 3,
  "name": "Kick Ad Blocker",
  "short_name": "KAB",
  "version": "1.3.0",
  "description": "Block ads on Kick.com — lightweight MV3 extension for Chrome, Brave, Edge & Firefox.",
  "icons": {
    "16": "public/icons/icon16.png",
    "32": "public/icons/icon32.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "32": "public/icons/icon32.png"
    },
    "default_title": "Kick Ad Blocker"
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.js"
      ],
      "matches": [
        "https://kick.com/*",
        "https://www.kick.com/*"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "permissions": [
    "storage",
    "alarms",
    "declarativeNetRequest",
    "webRequest"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "host_permissions": [
    "https://kick.com/*",
    "https://www.kick.com/*",
    "https://*.live-video.net/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ad_rules",
        "enabled": true,
        "path": "rules/ad-domains.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "matches": [
        "https://kick.com/*",
        "https://www.kick.com/*"
      ],
      "resources": [
        "googletag-stub.js",
        "hls-proxy.js",
        "assets/settings-DLvOkzep.js",
        "assets/messages-CiZFul6x.js",
        "assets/index.ts-3EHu3oUK.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
