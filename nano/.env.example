# Copie ce fichier en .env et remplis les valeurs

# Token du bot Telegram (obtenu via @BotFather)
TELEGRAM_BOT_TOKEN=ton_token_ici

# IDs Telegram autorisés (séparés par des virgules)
ALLOWED_USER_IDS=123456789

# IP locale du PC
PC_HOST=192.168.1.6

# Port du relai (doit être identique dans pc_relay.py et nano_bot.py)
RELAY_PORT=8765

# Token secret partagé entre bot et relai (choisis quelque chose de long)
RELAY_TOKEN=un_token_secret_long_et_aleatoire
